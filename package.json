{
  "name": "dataset-generator",
  "version": "1.0.0",
  "description": "Q+A dataset generator for water and energy facts using Claude API",
  "main": "generateDataset.js",
  "config": {
    "server": "ec2-52-53-196-217.us-west-1.compute.amazonaws.com",
    "key": "./secrets/ask-nereus-key.pem",
    "user": "ubuntu"
  },
  "scripts": {
    "generate": "node scripts/generateDataset.js",
    "generate-test": "node scripts/generateDataset.js './data/input/test/DC Water Facts 10 of 100 What causes fouling in heat exchangers 2.3.2026 gn.docx'",
    "vectorize": "node scripts/vectorizeDataset.js",
    "generate-markdown": "node scripts/generateData.js './prompts/facts-markdown-prompt.xml' '.md'",
    "generate-video-script": "node scripts/generateVideoScript.js",
    "query": "node scripts/query.js",
    "clear-all": "rm -rf node_modules/ && npm cache clean --force",
    "docs": "npx documentation build src/**/*.js -f html -o docs",
    "docs:watch": "npx documentation build src/**/*.js -f html -o docs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lintdiff": "git diff --name-only --cached --relative | grep '\\.js$' | xargs standard | snazzy",
    "verbose-test": "NODE_OPTIONS=--experimental-vm-modules jest --verbose --silent=false",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --silent=false",
    "update": "npx npm-check-updates -u; npm update; npm install",
    "sync": "rsync -avz --exclude 'node_modules' --exclude 'secrets' -e \"ssh -i $npm_package_config_key\" ./ $npm_package_config_user@$npm_package_config_server:~/dataset/",
    "ssh": "ssh -i $npm_package_config_key $npm_package_config_user@$npm_package_config_server"
  },
  "keywords": [
    "claude",
    "dataset",
    "rag",
    "water",
    "energy",
    "qa"
  ],
  "author": "William Brendel",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@m2d/core": "^1.7.1",
    "@mohtasham/md-to-docx": "^2.6.1",
    "@xenova/transformers": "^2.17.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dictionary-en": "^4.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "markitdown-ts": "^0.0.10",
    "multer": "^2.1.1",
    "nspell": "^2.1.5"
  },
  "devDependencies": {
    "@eslint/create-config": "latest",
    "@eslint/js": "latest",
    "@jest/globals": "latest",
    "documentation": "^14.0.3",
    "eslint": "latest",
    "eslint-plugin-css": "latest",
    "eslint-plugin-json": "latest",
    "globals": "latest",
    "jest": "latest",
    "npm-check-updates": "latest"
  }
}
